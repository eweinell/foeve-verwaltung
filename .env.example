# foeve-verwaltung — Beispielkonfiguration
# Kopie als .env anlegen und Werte setzen. .env wird NIE committet (CLAUDE.md Regel 9).

# --- Anwendung ---
APP_ENV=prod
APP_DEBUG=false
APP_URL=https://verwaltung.example.de
APP_TIMEZONE=Europe/Berlin

# --- Datenbank (MariaDB) ---
DB_DSN="mysql:host=127.0.0.1;dbname=foeve_verwaltung;charset=utf8mb4"
DB_USER=foeve
DB_PASS=

# --- Krypto (IBAN-Verschlüsselung, CLAUDE.md Regel 3) ---
# 32-Byte-Schlüssel, base64-kodiert. Erzeugen mit:
#   php -r "echo base64_encode(sodium_crypto_secretbox_keygen()), PHP_EOL;"
APP_CRYPTO_KEY=

# --- SMTP (Versand über die Queue, symfony/mailer DSN) ---
MAIL_DSN="smtp://user:pass@smtp.example.de:587"
MAIL_ABSENDER_ADRESSE=verwaltung@example.de
MAIL_ABSENDER_NAME="Förderverein Gymnasium Herzogenrath"

# --- Session ---
# true nur hinter HTTPS (Produktion). Lokal ggf. false.
SESSION_SECURE=true
