{% extends 'layout.twig' %}
{% block titel %}Antrag{% endblock %}
{% block container_klasse %}antrag-seite{% endblock %}
{% block inhalt %}
    <div class="text-center">
        {% if ergebnis == 'ok' %}
            <div class="icon success">✓</div>
            <h1>Vielen Dank!</h1>
            <p>Ihr Mitgliedsantrag ist erfolgreich beim Förderverein des Städtischen Gymnasiums
                Herzogenrath eingegangen.</p>
            <div class="info-box text-left">
                <strong>Wie geht es weiter?</strong>
                <ul>
                    <li>Der Vorstand prüft Ihren Antrag.</li>
                    <li>Sie erhalten anschließend eine persönliche Willkommensnachricht des
                        Vereinsvorstands mit Ihrer Mandatsreferenz.</li>
                    <li>Der Jahresbeitrag wird per SEPA-Lastschrift eingezogen &ndash; Sie werden
                        mindestens 14 Tage vor dem Einzug per E-Mail informiert.</li>
                </ul>
            </div>
        {% elseif ergebnis == 'schon' %}
            <div class="icon success">✓</div>
            <h1>Bereits bestätigt</h1>
            <p>Dieser Antrag wurde bereits bestätigt. Sie müssen nichts weiter tun.</p>
        {% else %}
            <div class="icon error">✗</div>
            <h1>Fehler bei der Bestätigung</h1>
            <p>Der Bestätigungslink ist ungültig oder abgelaufen.</p>
            <a href="/antrag" class="button">Zum Antragsformular</a>
        {% endif %}

        <p class="feld-hinweis abstand-oben">
            Bei Fragen erreichen Sie uns unter
            <a href="mailto:foerderverein@gymnasium.herzogenrath.de">foerderverein@gymnasium.herzogenrath.de</a>
        </p>
    </div>
{% endblock %}
