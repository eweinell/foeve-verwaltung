{% extends 'layout.twig' %}
{% block titel %}{{ mitglied.nachname }}{% endblock %}
{% macro feld(label, wert) %}
    <div class="form-group" style="margin-bottom:12px">
        <label style="margin-bottom:2px">{{ label }}</label>
        <div>{{ wert|default('—') }}</div>
    </div>
{% endmacro %}
{% import _self as ui %}
{% block inhalt %}
    {% set anzeigename = mitglied.anrede == 'familie' ? 'Familie ' ~ mitglied.nachname : (mitglied.vorname ? mitglied.vorname ~ ' ' ~ mitglied.nachname : mitglied.nachname) %}
    <div class="seitenkopf">
        <div>
            <h1>{{ anzeigename }}
                <span class="badge {{ status_meta[mitglied.status].badge }}">{{ status_meta[mitglied.status].label }}</span>
            </h1>
            <p class="untertitel">
                {{ mitglied.mitgliedsnummer ? 'Mitglied Nr. %04d'|format(mitglied.mitgliedsnummer) : 'Noch keine Mitgliedsnummer' }}
                · Eintritt: {{ mitglied.eintrittsdatum ? mitglied.eintrittsdatum|date('d.m.Y') : '—' }}
            </p>
        </div>
        <div class="zeile">
            <a href="/mitglieder" class="button button-sekundaer">Zur Liste</a>
            <a href="/mitglieder/{{ mitglied.id }}/bearbeiten" class="button">Bearbeiten</a>
        </div>
    </div>

    {# Statusaktionen #}
    <div class="karte eng">
        <div class="zeile">
            {% if mitglied.status == 'beantragt' %}
                <form method="post" action="/mitglieder/{{ mitglied.id }}/aktivieren" style="margin:0" onsubmit="return confirm('Mitglied aktivieren und Mitgliedsnummer vergeben?')">
                    <input type="hidden" name="{{ csrf_feld }}" value="{{ csrf_token }}">
                    <button class="button">Aktivieren</button>
                </form>
                <form method="post" action="/mitglieder/{{ mitglied.id }}/ablehnen" style="margin:0" onsubmit="return confirm('Antrag ablehnen?')">
                    <input type="hidden" name="{{ csrf_feld }}" value="{{ csrf_token }}">
                    <button class="button button-gefahr">Ablehnen</button>
                </form>
            {% elseif mitglied.status == 'aktiv' %}
                <details>
                    <summary class="button button-sekundaer" style="list-style:none">Kündigung erfassen</summary>
                    <form method="post" action="/mitglieder/{{ mitglied.id }}/kuendigen" class="karte" style="margin-top:10px;max-width:420px">
                        <input type="hidden" name="{{ csrf_feld }}" value="{{ csrf_token }}">
                        <div class="form-group">
                            <label for="kuendigung_am">Kündigungsdatum</label>
                            <input type="date" id="kuendigung_am" name="kuendigung_am">
                        </div>
                        <div class="form-group">
                            <label for="wirksam_zum">Wirksam zum</label>
                            <input type="date" id="wirksam_zum" name="wirksam_zum">
                            <div class="feld-hinweis">Leer lassen für 31.12. des laufenden Jahres.</div>
                        </div>
                        <button class="button button-gefahr">Kündigung speichern</button>
                    </form>
                </details>
            {% elseif mitglied.status == 'gekuendigt' %}
                <form method="post" action="/mitglieder/{{ mitglied.id }}/kuendigung-widerrufen" style="margin:0">
                    <input type="hidden" name="{{ csrf_feld }}" value="{{ csrf_token }}">
                    <button class="button">Kündigung widerrufen</button>
                </form>
                <form method="post" action="/mitglieder/{{ mitglied.id }}/austritt" style="margin:0" onsubmit="return confirm('Austritt jetzt vollziehen?')">
                    <input type="hidden" name="{{ csrf_feld }}" value="{{ csrf_token }}">
                    <button class="button button-sekundaer">Austritt vollziehen</button>
                </form>
                <span class="feld-hinweis">Wirksam zum {{ mitglied.wirksam_zum ? mitglied.wirksam_zum|date('d.m.Y') : '—' }}</span>
            {% else %}
                <span class="feld-hinweis">Keine Statusaktionen für den Status „{{ status_meta[mitglied.status].label }}".</span>
            {% endif %}
        </div>
    </div>

    {# Reiter #}
    {% set tabs = {'stammdaten': 'Stammdaten', 'mandate': 'Mandate', 'beitraege': 'Beiträge', 'email': 'E-Mail-Historie', 'historie': 'Änderungshistorie'} %}
    <div class="zeile" style="gap:4px;border-bottom:1px solid var(--rahmen-leicht);margin-bottom:18px">
        {% for schluessel, label in tabs %}
            <a href="/mitglieder/{{ mitglied.id }}?tab={{ schluessel }}"
               class="button button-klein {{ tab == schluessel ? '' : 'button-sekundaer' }}"
               style="border-bottom-left-radius:0;border-bottom-right-radius:0">{{ label }}</a>
        {% endfor %}
    </div>

    {% if tab == 'stammdaten' %}
        <div class="karte" style="max-width:760px">
            <div class="form-raster">
                {{ ui.feld('Briefanrede', briefanrede) }}
                {{ ui.feld('Adresszeile', mitglied.adresszeile_manuell) }}
                {{ ui.feld('Vorname', mitglied.vorname) }}
                {{ ui.feld('Nachname', mitglied.nachname) }}
                {{ ui.feld('Straße', mitglied.strasse) }}
                {{ ui.feld('PLZ / Ort', (mitglied.plz ~ ' ' ~ mitglied.ort)|trim) }}
                {{ ui.feld('Land', laender[mitglied.land]|default(mitglied.land)) }}
                {{ ui.feld('E-Mail', mitglied.kein_email_kontakt ? (mitglied.email ~ ' (kein E-Mail-Kontakt)')|trim : mitglied.email) }}
                {{ ui.feld('Telefon', mitglied.telefon) }}
                {{ ui.feld('Zahlweise', mitglied.zahlweise == 'lastschrift' ? 'Lastschrift' : 'Selbstzahler') }}
            </div>
            <div class="info-box" style="white-space:pre-line">{{ postanschrift|join("\n") }}</div>

            <h3>Jahresbeitrag</h3>
            <form method="post" action="/mitglieder/{{ mitglied.id }}/beitrag" class="stapel">
                <input type="hidden" name="{{ csrf_feld }}" value="{{ csrf_token }}">
                <div class="zeile">
                    <input type="text" name="beitrag" value="{{ '%.2f'|format(mitglied.jahresbeitrag)|replace({'.': ','}) }}" style="max-width:140px">
                    <span>€</span>
                    <button class="button button-sekundaer">Beitrag ändern</button>
                </div>
                {% if offene_forderung_lfd %}
                    <label class="checkbox-group" style="margin:0">
                        <input type="checkbox" name="auch_forderung" value="1">
                        <span>Offene Forderung des laufenden Jahres ebenfalls anpassen (§3.5)</span>
                    </label>
                {% endif %}
            </form>
            {% if mitglied.notizen %}<h3>Notizen</h3><p>{{ mitglied.notizen|nl2br }}</p>{% endif %}
        </div>
    {% elseif tab == 'mandate' %}
        <div class="karte" style="max-width:820px">
            <div class="seitenkopf" style="margin-bottom:10px">
                <h2 style="margin:0">SEPA-Mandate</h2>
                <span>Zahlweise: <strong>{{ mitglied.zahlweise == 'lastschrift' ? 'Lastschrift' : 'Selbstzahler' }}</strong></span>
            </div>

            <div class="tabelle-huelle">
                <table class="daten">
                    <thead><tr><th>Referenz</th><th>IBAN</th><th>Kontoinhaber</th><th>Erteilt</th><th>Sequenz</th><th>Status</th><th></th></tr></thead>
                    <tbody>
                        {% for m in mandate %}
                            <tr>
                                <td class="mono">{{ m.mandatsreferenz }}</td>
                                <td class="iban">{{ m.iban_maskiert }}</td>
                                <td>{{ m.kontoinhaber }}</td>
                                <td>{{ m.erteilt_am ? m.erteilt_am|date('d.m.Y') : '—' }}</td>
                                <td>{{ m.sequenz_genutzt ? 'RCUR' : 'FRST' }}</td>
                                <td>
                                    <span class="badge {{ m.status_badge }}">{{ m.status_label }}</span>
                                    {% if m.verfallen %}<span class="badge badge-warn" title="36 Monate ungenutzt">verfallen?</span>{% endif %}
                                </td>
                                <td>
                                    {% if m.status == 'aktiv' %}
                                        <div class="zeile">
                                            <form method="post" action="/mandat/{{ m.id }}/widerruf" style="margin:0" onsubmit="return confirm('Mandat widerrufen? Das Mitglied wird auf Selbstzahler gestellt.')">
                                                <input type="hidden" name="{{ csrf_feld }}" value="{{ csrf_token }}">
                                                <button class="button button-gefahr button-klein">Widerrufen</button>
                                            </form>
                                            <form method="post" action="/mandat/{{ m.id }}/deaktivieren" style="margin:0">
                                                <input type="hidden" name="{{ csrf_feld }}" value="{{ csrf_token }}">
                                                <button class="button button-sekundaer button-klein">Deaktivieren</button>
                                            </form>
                                        </div>
                                    {% endif %}
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="7" class="text-center">Noch kein Mandat.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <h3>Neues Mandat / Bankwechsel</h3>
            <div class="info-box">Ein Bankwechsel legt ein neues Mandat (FRST) an und deaktiviert das bisherige automatisch.</div>
            <form method="post" action="/mitglieder/{{ mitglied.id }}/mandat" class="form-raster">
                <input type="hidden" name="{{ csrf_feld }}" value="{{ csrf_token }}">
                <div class="form-group spanne-2">
                    <label for="iban">IBAN</label>
                    <input type="text" id="iban" name="iban" placeholder="DE.. / BE.. / NL.." required>
                </div>
                <div class="form-group">
                    <label for="kontoinhaber">Kontoinhaber</label>
                    <input type="text" id="kontoinhaber" name="kontoinhaber" placeholder="Default: Nachname">
                </div>
                <div class="form-group">
                    <label for="bic">BIC (optional)</label>
                    <input type="text" id="bic" name="bic">
                </div>
                <div class="form-group spanne-2">
                    <button class="button">Mandat anlegen</button>
                </div>
            </form>

            <h3>Zahlweise umstellen</h3>
            <form method="post" action="/mitglieder/{{ mitglied.id }}/zahlweise" class="zeile">
                <input type="hidden" name="{{ csrf_feld }}" value="{{ csrf_token }}">
                <select name="zahlweise">
                    <option value="lastschrift" {{ mitglied.zahlweise == 'lastschrift' ? 'selected' : '' }}>Lastschrift</option>
                    <option value="selbstzahler" {{ mitglied.zahlweise == 'selbstzahler' ? 'selected' : '' }}>Selbstzahler</option>
                </select>
                <label class="checkbox-group" style="margin:0">
                    <input type="checkbox" name="mandat_deaktivieren" value="1">
                    <span>aktives Mandat dabei deaktivieren</span>
                </label>
                <button class="button button-sekundaer">Umstellen</button>
            </form>
        </div>
    {% elseif tab == 'beitraege' %}
        <div class="karte" style="max-width:820px">
            <div class="tabelle-huelle">
                <table class="daten">
                    <thead><tr><th>Jahr</th><th>Typ</th><th class="num">Betrag</th><th>Status</th><th>Bezahlt</th><th></th></tr></thead>
                    <tbody>
                        {% for f in forderungen %}
                            <tr>
                                <td>{{ f.jahr }}</td>
                                <td>{{ f.typ == 'beitrag' ? 'Beitrag' : 'Gebühr' }}</td>
                                <td class="num">{{ '%.2f'|format(f.betrag)|replace({'.': ','}) }} €</td>
                                <td><span class="badge {{ f.status_badge }}">{{ f.status_label }}</span></td>
                                <td>{{ f.bezahlt_am ? f.bezahlt_am|date('d.m.Y') ~ ' (' ~ f.zahlungsart ~ ')' : '—' }}</td>
                                <td>
                                    <div class="zeile">
                                        {% if f.status in ['offen', 'ruecklastschrift'] %}
                                            <details>
                                                <summary class="button button-sekundaer button-klein" style="list-style:none">bezahlt</summary>
                                                <form method="post" action="/forderung/{{ f.id }}/bezahlt" class="karte eng" style="margin-top:6px">
                                                    <input type="hidden" name="{{ csrf_feld }}" value="{{ csrf_token }}">
                                                    <select name="zahlungsart">
                                                        <option value="ueberweisung">Überweisung</option>
                                                        <option value="bar">Bar</option>
                                                    </select>
                                                    <input type="date" name="datum">
                                                    <button class="button button-klein">Speichern</button>
                                                </form>
                                            </details>
                                            <form method="post" action="/forderung/{{ f.id }}/storno" style="margin:0" onsubmit="return confirm('Forderung stornieren? (kein Löschen)')">
                                                <input type="hidden" name="{{ csrf_feld }}" value="{{ csrf_token }}">
                                                <button class="button button-gefahr button-klein">Storno</button>
                                            </form>
                                        {% endif %}
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="6" class="text-center">Noch keine Forderungen.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <h3>Gebühr / Einzelforderung anlegen</h3>
            <form method="post" action="/mitglieder/{{ mitglied.id }}/gebuehr" class="zeile">
                <input type="hidden" name="{{ csrf_feld }}" value="{{ csrf_token }}">
                <input type="text" name="betrag" placeholder="Betrag" style="max-width:120px"> €
                <input type="number" name="jahr" value="{{ 'now'|date('Y') }}" style="max-width:110px">
                <button class="button button-sekundaer">Gebühr anlegen</button>
            </form>
        </div>
    {% elseif tab == 'email' %}
        <div class="tabelle-huelle">
            <table class="daten">
                <thead><tr><th>Zeitpunkt</th><th>Betreff</th><th>Status</th></tr></thead>
                <tbody>
                    {% for e in emails %}
                        <tr>
                            <td class="mono">{{ (e.gesendet_am ?? e.geplant_ab)|date('d.m.Y H:i') }}</td>
                            <td>{{ e.betreff }}</td>
                            <td><span class="badge {{ e.status == 'gesendet' ? 'badge-erfolg' : (e.status == 'fehler' ? 'badge-fehler' : 'badge-info') }}">{{ e.status }}</span></td>
                        </tr>
                    {% else %}
                        <tr><td colspan="3" class="text-center">Noch keine E-Mails.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    {% elseif tab == 'historie' %}
        {% for e in historie %}
            <div class="karte eng">
                <div class="zeile" style="justify-content:space-between">
                    <div>
                        <strong>Version {{ e.version_nr }}</strong>
                        {% if e.ist_revert %}<span class="badge badge-info">Revert</span>{% endif %}
                        <span class="feld-hinweis">{{ e.wann|date('d.m.Y H:i') }} · {{ e.wer }}</span>
                    </div>
                    <form method="post" action="/mitglieder/{{ mitglied.id }}/revert" style="margin:0"
                          onsubmit="return confirm('Auf diesen Stand zurücksetzen? Es wird eine neue Version erstellt.')">
                        <input type="hidden" name="{{ csrf_feld }}" value="{{ csrf_token }}">
                        <input type="hidden" name="version_id" value="{{ e.version_id }}">
                        <button class="button button-sekundaer button-klein">Auf diesen Stand zurücksetzen</button>
                    </form>
                </div>
                <table class="daten" style="margin-top:8px">
                    <thead><tr><th>Feld</th><th>alt</th><th>neu</th><th></th></tr></thead>
                    <tbody>
                        {% for d in e.diffs %}
                            <tr>
                                <td>{{ d.feld }}</td>
                                <td>{{ d.alt }}</td>
                                <td>{{ d.neu }}</td>
                                <td>
                                    <form method="post" action="/mitglieder/{{ mitglied.id }}/revert" style="margin:0">
                                        <input type="hidden" name="{{ csrf_feld }}" value="{{ csrf_token }}">
                                        <input type="hidden" name="version_id" value="{{ e.version_id }}">
                                        <input type="hidden" name="feld" value="{{ d.feld }}">
                                        <button class="button button-sekundaer button-klein" title="Nur dieses Feld übernehmen">Feld übernehmen</button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% else %}
            <div class="karte"><p class="text-center">Noch keine Änderungen.</p></div>
        {% endfor %}
    {% endif %}
{% endblock %}
