{% extends 'layout.twig' %}
{% block titel %}Start{% endblock %}
{% block inhalt %}
    <div class="seitenkopf">
        <div>
            <h1>Willkommen, {{ aktueller_benutzer.name }}</h1>
            <p class="untertitel">Vereinsverwaltung — Grundgerüst (AP0). Die Fachmodule folgen in den nächsten Arbeitspaketen.</p>
        </div>
    </div>

    <div class="karte">
        <h2 style="margin-top:0">Nächste Schritte</h2>
        <div class="info-box">
            <strong>Hinweis:</strong> Sichern Sie Ihr Konto über
            <a href="/profil">Profil &amp; Zwei-Faktor</a>. Als Administrator verwalten Sie unter
            <a href="/einstellungen">Einstellungen</a> Benutzer, Drosselrate und das Audit-Log.
        </div>
        <ul style="margin:12px 0 0 20px; color:var(--text-normal)">
            <li>Mitglieder &amp; Anträge — folgt in AP1</li>
            <li>Mandate &amp; Sollstellung — folgt in AP2</li>
            <li>SEPA-Einzug — folgt in AP3</li>
        </ul>
    </div>
{% endblock %}
