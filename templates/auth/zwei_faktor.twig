{% extends 'layout.twig' %}
{% block titel %}Zweiter Faktor{% endblock %}
{% block container_klasse %}inhalt-schmal{% endblock %}
{% block inhalt %}
    <div class="karte">
        <h1>Bestätigung</h1>
        {% if methode == 'totp' %}
            <p class="untertitel">Bitte geben Sie den 6-stelligen Code aus Ihrer Authenticator-App ein.</p>
        {% else %}
            <p class="untertitel">Wir haben Ihnen einen 6-stelligen Code per E-Mail geschickt. Bitte geben Sie ihn ein.</p>
        {% endif %}
        <form method="post" action="/login/2fa" class="stapel">
            <input type="hidden" name="{{ csrf_feld }}" value="{{ csrf_token }}">
            <div class="form-group">
                <label for="code">Code</label>
                <input type="text" id="code" name="code" inputmode="numeric" autocomplete="one-time-code"
                       pattern="[0-9]*" maxlength="6" required autofocus>
            </div>
            <button type="submit" class="button button-voll">Bestätigen</button>
        </form>
    </div>
{% endblock %}
