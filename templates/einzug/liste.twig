{% extends 'layout.twig' %}
{% block titel %}Einzugsläufe{% endblock %}
{% block inhalt %}
    <div class="seitenkopf">
        <div>
            <h1>SEPA-Einzugsläufe</h1>
            <p class="untertitel">Beitragsforderungen bündeln, ankündigen und als pain.008-Datei fürs Online-Banking exportieren.</p>
        </div>
    </div>

    <div class="karte">
        <h2 style="margin-top:0">Neuen Lauf anlegen</h2>
        <div class="info-box">Aufgenommen werden alle offenen Forderungen mit Zahlweise „Lastschrift" und aktivem Mandat. Fälligkeit mindestens 2 Bankarbeitstage in der Zukunft.</div>
        <form method="post" action="/einzug" class="form-raster">
            <input type="hidden" name="{{ csrf_feld }}" value="{{ csrf_token }}">
            <div class="form-group">
                <label for="bezeichnung">Bezeichnung</label>
                <input type="text" id="bezeichnung" name="bezeichnung" placeholder="z. B. Jahreseinzug {{ 'now'|date('Y') }}" required>
            </div>
            <div class="form-group">
                <label for="faelligkeitsdatum">Fälligkeitsdatum</label>
                <input type="date" id="faelligkeitsdatum" name="faelligkeitsdatum" required>
            </div>
            <div class="form-group" style="display:flex;align-items:flex-end">
                <button type="submit" class="button">Lauf anlegen</button>
            </div>
        </form>
    </div>

    <div class="tabelle-huelle">
        <table class="daten">
            <thead><tr><th>Bezeichnung</th><th>Fälligkeit</th><th class="num">Positionen</th><th class="num">Summe</th><th>Status</th><th></th></tr></thead>
            <tbody>
                {% for l in laeufe %}
                    <tr>
                        <td>{{ l.bezeichnung }}</td>
                        <td>{{ l.faelligkeitsdatum|date('d.m.Y') }}</td>
                        <td class="num">{{ l.anzahl }}</td>
                        <td class="num">{{ '%.2f'|format(l.summe)|replace({'.': ','}) }} €</td>
                        <td><span class="badge {{ l.status_badge }}">{{ l.status_label }}</span></td>
                        <td><a href="/einzug/{{ l.id }}" class="button button-sekundaer button-klein">Öffnen</a></td>
                    </tr>
                {% else %}
                    <tr><td colspan="6" class="text-center">Noch keine Einzugsläufe.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
