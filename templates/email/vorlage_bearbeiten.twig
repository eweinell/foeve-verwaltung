{% extends 'layout.twig' %}
{% block titel %}Vorlage {{ vorlage.schluessel }}{% endblock %}
{% block inhalt %}
    <div class="seitenkopf">
        <div>
            <h1>Vorlage: <span class="mono">{{ vorlage.schluessel }}</span></h1>
            <p class="untertitel">{{ vorlage.system ? 'Systemvorlage' : 'Eigene Vorlage' }}{{ vorlage.ist_override ? ' (angepasst)' : '' }}</p>
        </div>
        <a href="/email/vorlagen" class="button button-sekundaer">Zurück</a>
    </div>

    <div class="karte" style="max-width:820px">
        <form method="post" action="/email/vorlagen/{{ vorlage.schluessel }}">
            <input type="hidden" name="{{ csrf_feld }}" value="{{ csrf_token }}">
            <div class="form-group">
                <label for="betreff">Betreff</label>
                <input type="text" id="betreff" name="betreff" value="{{ vorlage.betreff }}" {{ ist_admin ? '' : 'readonly' }}>
            </div>
            <div class="form-group">
                <label for="body_text">Text</label>
                <textarea id="body_text" name="body_text" rows="14" {{ ist_admin ? '' : 'readonly' }}>{{ vorlage.body_text }}</textarea>
            </div>
            <div class="form-group">
                <label for="body_html">HTML (optional)</label>
                <textarea id="body_html" name="body_html" rows="8" {{ ist_admin ? '' : 'readonly' }}>{{ vorlage.body_html }}</textarea>
            </div>
            <div class="info-box">
                Erlaubte Platzhalter: {% for p in platzhalter %}<span class="mono">{{ '{{' }}{{ p }}{{ '}}' }}</span>{{ not loop.last ? ', ' : '' }}{% endfor %}
            </div>
            {% if ist_admin %}
                <div class="zeile abstand-oben">
                    <button type="submit" class="button">Speichern</button>
                    {% if vorlage.ist_override or not vorlage.system %}
                        <button type="submit" formaction="/email/vorlagen/{{ vorlage.schluessel }}/zuruecksetzen" class="button button-sekundaer"
                                onclick="return confirm('{{ vorlage.system ? 'Auf Standardtext zurücksetzen?' : 'Vorlage löschen?' }}')">
                            {{ vorlage.system ? 'Auf Standard zurücksetzen' : 'Löschen' }}
                        </button>
                    {% endif %}
                </div>
            {% endif %}
        </form>
    </div>
{% endblock %}
